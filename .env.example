# ============================================================
# Sanando desde el Corazón — .env.example
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ============================================================

# ----------------------------------------------------------
# Entorno general
# ----------------------------------------------------------
ENVIRONMENT=development          # development | staging | production
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=cambia_esto_por_un_valor_aleatorio_seguro_256bits

# ----------------------------------------------------------
# JWT — RS256 (rutas a los archivos PEM en el servidor)
# Genera con: openssl genrsa -out jwt_private.pem 4096
#             openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# ----------------------------------------------------------
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ----------------------------------------------------------
# PostgreSQL — 5 instancias independientes
# ----------------------------------------------------------

# 1. clinical_db  (expedientes clínicos — PII cifrado con pgcrypto)
CLINICAL_DB_HOST=clinical-postgres
CLINICAL_DB_PORT=5432
CLINICAL_DB_NAME=clinical_db
CLINICAL_DB_USER=clinical_user
CLINICAL_DB_PASSWORD=cambia_esto_clinical
CLINICAL_DATABASE_URL=postgresql+psycopg://clinical_user:cambia_esto_clinical@clinical-postgres:5432/clinical_db
CLINICAL_DB_PGCRYPTO_KEY=cambia_esto_clave_cifrado_pii_32chars

# 2. portal_db  (portal de cursos)
PORTAL_DB_HOST=portal-postgres
PORTAL_DB_PORT=5433
PORTAL_DB_NAME=portal_db
PORTAL_DB_USER=portal_user
PORTAL_DB_PASSWORD=cambia_esto_portal
PORTAL_DATABASE_URL=postgresql+psycopg://portal_user:cambia_esto_portal@portal-postgres:5433/portal_db

# 3. podcast_db  (podcast)
PODCAST_DB_HOST=podcast-postgres
PODCAST_DB_PORT=5434
PODCAST_DB_NAME=podcast_db
PODCAST_DB_USER=podcast_user
PODCAST_DB_PASSWORD=cambia_esto_podcast
PODCAST_DATABASE_URL=postgresql+psycopg://podcast_user:cambia_esto_podcast@podcast-postgres:5434/podcast_db

# 4. auth_db  (tokens, sesiones, refresh tokens)
AUTH_DB_HOST=auth-postgres
AUTH_DB_PORT=5435
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=cambia_esto_auth
AUTH_DATABASE_URL=postgresql+psycopg://auth_user:cambia_esto_auth@auth-postgres:5435/auth_db

# 5. audit_db  (audit log INSERT-only — nunca UPDATE/DELETE)
AUDIT_DB_HOST=audit-postgres
AUDIT_DB_PORT=5436
AUDIT_DB_NAME=audit_db
AUDIT_DB_USER=audit_user
AUDIT_DB_PASSWORD=cambia_esto_audit
AUDIT_DATABASE_URL=postgresql+psycopg://audit_user:cambia_esto_audit@audit-postgres:5436/audit_db

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=cambia_esto_redis
REDIS_URL=redis://:cambia_esto_redis@redis:6379/0
REDIS_DB_SESSIONS=0
REDIS_DB_CACHE=1
REDIS_DB_RATE_LIMIT=2

# ----------------------------------------------------------
# MinIO (almacenamiento de archivos)
# ----------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=cambia_esto_minio
MINIO_USE_SSL=false
MINIO_BUCKET_CLINICAL=clinical-files
MINIO_BUCKET_PORTAL=portal-assets
MINIO_BUCKET_PODCAST=podcast-media
MINIO_BUCKET_BACKUPS=backups

# ----------------------------------------------------------
# Clinical API (puerto 8001)
# ----------------------------------------------------------
CLINICAL_API_HOST=0.0.0.0
CLINICAL_API_PORT=8001
CLINICAL_CORS_ORIGINS=https://sanandodesdeelcorazon.com,http://localhost:3002
CLINICAL_DOCS_ENABLED=false   # Debe ser false en producción

# ----------------------------------------------------------
# Portal API (puerto 8002)
# ----------------------------------------------------------
PORTAL_API_HOST=0.0.0.0
PORTAL_API_PORT=8002
PORTAL_CORS_ORIGINS=https://sanandodesdeelcorazon.com,http://localhost:3002
PORTAL_DOCS_ENABLED=false

# Pasarela de pago (cursos)
STRIPE_SECRET_KEY=sk_test_cambia_esto
STRIPE_WEBHOOK_SECRET=whsec_cambia_esto
STRIPE_PRICE_ID_CURSO_BASE=price_cambia_esto

# ----------------------------------------------------------
# Podcast API (puerto 8003)
# ----------------------------------------------------------
PODCAST_API_HOST=0.0.0.0
PODCAST_API_PORT=8003
PODCAST_CORS_ORIGINS=https://sanandodesdeelcorazon.com,http://localhost:3002
PODCAST_DOCS_ENABLED=false

# RSS / distribución de podcast
PODCAST_TITLE=Sanando desde el Corazón
PODCAST_BASE_URL=https://sanandodesdeelcorazon.com/podcast

# ----------------------------------------------------------
# Frontend — Next.js (puerto 3002)
# NEXT_PUBLIC_* son visibles en el navegador — no pongas secretos aquí
# ----------------------------------------------------------
NEXT_PUBLIC_CLINICAL_API_URL=http://localhost:8001
NEXT_PUBLIC_PORTAL_API_URL=http://localhost:8002
NEXT_PUBLIC_PODCAST_API_URL=http://localhost:8003
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_SITE_URL=https://sanandodesdeelcorazon.com

# ----------------------------------------------------------
# Nginx / TLS
# ----------------------------------------------------------
NGINX_HOST=sanandodesdeelcorazon.com
CERTBOT_EMAIL=admin@sanandodesdeelcorazon.com

# ----------------------------------------------------------
# Email (notificaciones, recuperación de contraseña)
# ----------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@sanandodesdeelcorazon.com
SMTP_PASSWORD=cambia_esto_smtp
SMTP_FROM_NAME=Sanando desde el Corazón
SMTP_TLS=true

# ----------------------------------------------------------
# Migración Notion → PostgreSQL
# ----------------------------------------------------------
NOTION_API_KEY=secret_cambia_esto_notion
NOTION_DATABASE_ID_PACIENTES=cambia_esto_db_id
NOTION_DATABASE_ID_SESIONES=cambia_esto_db_id
NOTION_DATABASE_ID_CITAS=cambia_esto_db_id

# ----------------------------------------------------------
# Docker Compose (variables para los contenedores de Postgres)
# Se usan en la inicialización de cada instancia
# ----------------------------------------------------------
CLINICAL_POSTGRES_USER=${CLINICAL_DB_USER}
CLINICAL_POSTGRES_PASSWORD=${CLINICAL_DB_PASSWORD}
CLINICAL_POSTGRES_DB=${CLINICAL_DB_NAME}

PORTAL_POSTGRES_USER=${PORTAL_DB_USER}
PORTAL_POSTGRES_PASSWORD=${PORTAL_DB_PASSWORD}
PORTAL_POSTGRES_DB=${PORTAL_DB_NAME}

PODCAST_POSTGRES_USER=${PODCAST_DB_USER}
PODCAST_POSTGRES_PASSWORD=${PODCAST_DB_PASSWORD}
PODCAST_POSTGRES_DB=${PODCAST_DB_NAME}

AUTH_POSTGRES_USER=${AUTH_DB_USER}
AUTH_POSTGRES_PASSWORD=${AUTH_DB_PASSWORD}
AUTH_POSTGRES_DB=${AUTH_DB_NAME}

AUDIT_POSTGRES_USER=${AUDIT_DB_USER}
AUDIT_POSTGRES_PASSWORD=${AUDIT_DB_PASSWORD}
AUDIT_POSTGRES_DB=${AUDIT_DB_NAME}
