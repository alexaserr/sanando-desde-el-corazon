# ============================================================
# Sanando desde el Corazón — .gitignore
# Python + Node.js + Docker + Secrets + IDE
# ============================================================

# ----------------------------------------------------------
# Secrets & Environment — NUNCA en Git
# ----------------------------------------------------------
.env
.env.*
.env.local
.env.production
.env.*.local
!.env.example
*.pem
*.key
*.crt
jwt_private.pem
jwt_public.pem

# ----------------------------------------------------------
# Python
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.venv/
venv/
.python-version

# Testing & Linting
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ----------------------------------------------------------
# Node.js / Next.js
# ----------------------------------------------------------
node_modules/
.next/
out/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------
docker-compose.override.yml

# ----------------------------------------------------------
# PostgreSQL / Database
# ----------------------------------------------------------
*.sql.enc
*.dump
*.pgdata/

# ----------------------------------------------------------
# MinIO / Storage local
# ----------------------------------------------------------
minio-data/
peertube-data/

# ----------------------------------------------------------
# Migración de Notion (datos temporales)
# ----------------------------------------------------------
migration/reports/*.json
migration/data/

# ----------------------------------------------------------
# Backups locales
# ----------------------------------------------------------
backups/
*.bak

# ----------------------------------------------------------
# Nginx — certs se generan en el servidor
# ----------------------------------------------------------
nginx/certs/
certbot/
letsencrypt/

# ----------------------------------------------------------
# IDE / Editors
# ----------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ----------------------------------------------------------
# OS
# ----------------------------------------------------------
.DS_Store
Thumbs.db
*.log
logs/
*.pid
*.seed

# ----------------------------------------------------------
# Claude Code (settings locales del desarrollador)
# ----------------------------------------------------------
.claude/
!.claude/settings.jsonfrontend/tsconfig.tsbuildinfo
